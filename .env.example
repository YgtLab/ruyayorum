# Environment mode / Çalışma modu
NODE_ENV=development
# Server port / Sunucu portu
PORT=3000
# Allowed frontend origin / İzinli frontend origin
ALLOWED_ORIGIN=http://localhost:3000
# Public app URL / Uygulama URL
APP_URL=http://localhost:3000
# MongoDB connection string / MongoDB bağlantı dizesi
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>
# JWT secret (set a long random value) / JWT gizli anahtarı (uzun rastgele değer ver)
JWT_SECRET=replace_with_a_long_random_secret
# JWT expiry (access token) / JWT süresi (erişim tokenı)
JWT_ACCESS_EXPIRE=15m
# JWT expiry (refresh token) / JWT süresi (yenileme tokenı)
JWT_REFRESH_EXPIRE=30d
# Groq API key / Groq API anahtarı
GROQ_API_KEY=gsk_xxx
# Resend API key / Resend API anahtarı
RESEND_API_KEY=re_xxx
# Verified sender email / Doğrulanmış gönderen emaili
RESEND_FROM=onboarding@resend.dev
# Admin user email / Admin kullanıcı emaili
ADMIN_EMAIL=admin@example.com
# Redis connection URL / Redis bağlantı URL'i
REDIS_URL=redis://localhost:6379
# Global API rate limit / Genel API hız limiti
GENERAL_RATE_LIMIT_MAX=100
# Auth route rate limit / Auth route hız limiti
AUTH_RATE_LIMIT_MAX=5
